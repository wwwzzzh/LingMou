# ==========================================
# AI 视觉对话助手 — 环境变量配置模板
# 复制此文件为 .env.development 或 .env.production
# ==========================================

# API 基础地址
VITE_API_BASE_URL=http://localhost:8080

# 应用名称
VITE_APP_TITLE=AI 视觉对话助手

# 运行环境
VITE_APP_ENV=development

# 火山引擎 Ark API Key（豆包模型）
VITE_ARK_API_KEY=your_ark_api_key_here
